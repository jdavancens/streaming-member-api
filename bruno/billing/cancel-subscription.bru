meta {
  name: Cancel Subscription
  type: graphql
  seq: 3
}

post {
  url: {{baseUrl}}
  body: graphql
}

body:graphql {
  mutation CancelSubscription($memberId: ID!) {
    cancelSubscription(memberId: $memberId) {
      subscription {
        id
        status
        cancelledAt
      }
    }
  }
}

body:graphql:vars {
  {
    "memberId": "{{memberId}}"
  }
}
